:8px}.elementor-widget-text-editor:not(.elementor-drop-cap-view-default) .elementor-drop-cap-letter{width:1em;height:1em}.elementor-widget-text-editor .elementor-drop-cap{float:left;text-align:center;line-height:1;font-size:50px}.elementor-widget-text-editor .elementor-drop-cap-letter{display:inline-block}<\/style>\t\t\t\t<p><span data-contrast=\"auto\">Sam Precious Metals is proud to announce the signing of a strategic academic partnership between <\/span><b><span data-contrast=\"auto\">Sam Training Center<\/span><\/b><span data-contrast=\"auto\"> and the <\/span><b><span data-contrast=\"auto\">\u00c9cole de Commerce de Lyon<\/span><\/b><span data-contrast=\"auto\">, one of Europe\u2019s leading business schools recognized for its global academic footprint, innovation-focused curriculum, and international executive education programs.<\/span><span data-ccp-props=\"{}\">\u00a0<\/span><\/p><p><span data-contrast=\"auto\">With this association, the <\/span><b><span data-contrast=\"auto\">Sam Training Center<\/span><\/b><span data-contrast=\"auto\"> is now renamed to <\/span><b><span data-contrast=\"auto\">Sam Precious Metals Academy<\/span><\/b><span data-contrast=\"auto\"> and holds full accreditation as a higher-education institution empowered to confer formally recognized academic degrees. This milestone transitions our academic platform beyond professional certification into a structured degree-granting model, supported by collaborative curriculum development, faculty exchange, credit pathways, and a globally connected academic structure.\u00a0<\/span><span data-ccp-props=\"{}\">\u00a0<\/span><\/p><p><span data-contrast=\"auto\">Students and faculty will benefit from coordinated academic programs delivered across <\/span><strong>11 international branches of \u00c9cole de Commerce de Lyon<\/strong><span data-contrast=\"auto\">, delivered both physically and virtually, enabling global access to structured, industry-aligned learning.<\/span><span data-ccp-props=\"{}\">\u00a0<\/span><\/p><p><span data-contrast=\"auto\">This partnership reflects our long-standing commitment to academic rigor, ethical governance, and sector-specific specialization. The programs developed under this collaboration will foster a new generation of industry leaders equipped with the skills required to uphold transparency, compliance, sustainability, market integrity, and operational excellence within the global precious metals landscape.<\/span><span data-ccp-props=\"{}\">\u00a0<\/span><\/p><p><span data-contrast=\"auto\">With this initiative, Sam strengthens its position as a catalyst for knowledge transfer and institutional development in our industry \u2013 building pathways that are not only educational, but foundational to a more responsible and professionally equipped global precious-metals ecosystem.<\/span><span data-ccp-props=\"{}\">\u00a0<\/span><\/p><p><span data-contrast=\"auto\">Additional program information and formal academic timelines will be shared as the next phase is announced.<\/span><span data-ccp-props=\"{}\">\u00a0<\/span><\/p>\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<section class=\"has_eae_slider elementor-section elementor-top-section elementor-element elementor-element-4561b90 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-eae-slider=\"91430\" data-id=\"4561b90\" data-element_type=\"section\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"has_eae_slider elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-9c3d705\" data-eae-slider=\"38093\" data-id=\"9c3d705\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-77514e3 elementor-widget elementor-widget-heading\" data-id=\"77514e3\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<style>\/*! elementor - v3.22.0 - 24-06-2024 *\/\n.elementor-heading-title{padding:0;margin:0;line-height:1}.elementor-widget-heading .elementor-heading-title[class*=elementor-size-]>a{color:inherit;font-size:inherit;line-height:inherit}.elementor-widget-heading .elementor-heading-title.elementor-size-small{font-size:15px}.elementor-widget-heading .elementor-heading-title.elementor-size-medium{font-size:19px}.elementor-widget-heading .elementor-heading-title.elementor-size-large{font-size:29px}.elementor-widget-heading .elementor-heading-title.elementor-size-xl{font-size:39px}.elementor-widget-heading .elementor-heading-title.elementor-size-xxl{font-size:59px}<\/style><h2 class=\"elementor-heading-title elementor-size-default\">Sam renforce le d\u00e9veloppement acad\u00e9mique mondial gr\u00e2ce \u00e0 un partenariat avec l\u2019\u00c9cole de Commerce de Lyon <\/h2>\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<section class=\"has_eae_slider elementor-section elementor-top-section elementor-element elementor-element-47d14a7 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-eae-slider=\"89240\" data-id=\"47d14a7\" data-element_type=\"section\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"has_eae_slider elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-0f5ada7\" data-eae-slider=\"60838\" data-id=\"0f5ada7\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-083aa33 elementor-widget elementor-widget-text-editor\" data-id=\"083aa33\" data-element_type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t<p><span data-contrast=\"none\">Sam Precious Metals est fier d\u2019annoncer la signature d\u2019un\u202f<\/span><b><span data-contrast=\"none\">partenariat acad\u00e9mique strat\u00e9gique<\/span><\/b><span data-contrast=\"none\">\u202fentre le\u202f<\/span><b><span data-contrast=\"none\">Centre de Formation Sam<\/span><\/b><span data-contrast=\"none\">\u202fet l\u2019<\/span><b><span data-contrast=\"none\">\u00c9cole de Commerce de Lyon<\/span><\/b><span data-contrast=\"none\">, l\u2019une des principales \u00e9coles de commerce europ\u00e9ennes, reconnue pour sa port\u00e9e acad\u00e9mique internationale, son\u202f<\/span><b><span data-contrast=\"none\">enseignement ax\u00e9 sur l\u2019innovation<\/span><\/b><span data-contrast=\"none\">\u202fet ses\u202f<\/span><b><span data-contrast=\"none\">programmes de formation ex\u00e9cutive mondiale<\/span><\/b><span data-contrast=\"none\">.<\/span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\">\u00a0<\/span><\/p><p><span data-contrast=\"none\">Dans le cadre de cette association, le\u202f<\/span><b><span data-contrast=\"none\">Centre de Formation Sam<\/span><\/b><span data-contrast=\"none\">\u202fest d\u00e9sormais renomm\u00e9\u202f<\/span><b><span data-contrast=\"none\">Sam Precious Metals Academy<\/span><\/b><span data-contrast=\"none\">\u202fet obtient une\u202f<\/span><b><span data-contrast=\"none\">accr\u00e9ditation compl\u00e8te<\/span><\/b><span data-contrast=\"none\">\u202fen tant qu\u2019\u00e9tablissement d\u2019enseignement sup\u00e9rieur habilit\u00e9 \u00e0 d\u00e9livrer des\u202f<\/span><b><span data-contrast=\"none\">dipl\u00f4mes acad\u00e9miques reconnus officiellement<\/span><\/b><span data-contrast=\"none\">. Ce jalon marque la transition de notre plateforme \u00e9ducative au-del\u00e0 de la certification professionnelle vers un\u202f<\/span><b><span data-contrast=\"none\">mod\u00e8le structur\u00e9 d\u2019enseignement dipl\u00f4mant<\/span><\/b><span data-contrast=\"none\">, soutenu par un\u202f<\/span><b><span data-contrast=\"none\">d\u00e9veloppement conjoint des programmes<\/span><\/b><span data-contrast=\"none\">, des\u202f<\/span><b><span data-contrast=\"none\">\u00e9changes de professeurs<\/span><\/b><span data-contrast=\"none\">, des\u202f<\/span><b><span data-contrast=\"none\">passerelles de cr\u00e9dits<\/span><\/b><span data-contrast=\"none\">\u202fet une\u202f<\/span><b><span data-contrast=\"none\">structure acad\u00e9mique mondiale int\u00e9gr\u00e9e<\/span><\/b><span data-contrast=\"none\">.<\/span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\">\u00a0<\/span><\/p><p><span data-contrast=\"none\">Les \u00e9tudiants et enseignants b\u00e9n\u00e9ficieront de\u202f<\/span><b><span data-contrast=\"none\">programmes coordonn\u00e9s<\/span><\/b><span data-contrast=\"none\">\u202fdispens\u00e9s dans les\u202f<\/span><b><span data-contrast=\"none\">11 campus internationaux<\/span><\/b><span data-contrast=\"none\">\u202fde l\u2019\u00c9cole de Commerce de Lyon, propos\u00e9s \u00e0 la fois en pr\u00e9sentiel et en ligne, permettant ainsi un acc\u00e8s mondial \u00e0 un apprentissage structur\u00e9 et align\u00e9 sur les besoins du secteur.<\/span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\">\u00a0<\/span><\/p><p><span data-contrast=\"none\">Ce partenariat refl\u00e8te notre\u202f<\/span><b><span data-contrast=\"none\">engagement constant envers la rigueur acad\u00e9mique<\/span><\/b><span data-contrast=\"none\">, la\u202f<\/span><b><span data-contrast=\"none\">gouvernance \u00e9thique<\/span><\/b><span data-contrast=\"none\">\u202fet la\u202f<\/span><b><span data-contrast=\"none\">sp\u00e9cialisation sectorielle<\/span><\/b><span data-contrast=\"none\">. Les programmes d\u00e9velopp\u00e9s dans le cadre de cette collaboration formeront une\u202f<\/span><b><span data-contrast=\"none\">nouvelle g\u00e9n\u00e9ration de leaders du secteur<\/span><\/b><span data-contrast=\"none\">, dot\u00e9s des comp\u00e9tences n\u00e9cessaires pour garantir la\u202f<\/span><b><span data-contrast=\"none\">transparence<\/span><\/b><span data-contrast=\"none\">, la\u202f<\/span><b><span data-contrast=\"none\">conformit\u00e9<\/span><\/b><span data-contrast=\"none\">, la\u202f<\/span><b><span data-contrast=\"none\">durabilit\u00e9<\/span><\/b><span data-contrast=\"none\">, l\u2019<\/span><b><span data-contrast=\"none\">int\u00e9grit\u00e9 des march\u00e9s<\/span><\/b><span data-contrast=\"none\">\u202fet l\u2019<\/span><b><span data-contrast=\"none\">excellence op\u00e9rationnelle<\/span><\/b><span data-contrast=\"none\">\u202fdans l\u2019industrie mondiale des m\u00e9taux pr\u00e9cieux.<\/span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\">\u00a0<\/span><\/p><p><span data-contrast=\"none\">Avec cette initiative, Sam consolide son r\u00f4le de\u202f<\/span><b><span data-contrast=\"none\">catalyseur du transfert de connaissances<\/span><\/b><span data-contrast=\"none\">\u202fet du\u202f<\/span><b><span data-contrast=\"none\">d\u00e9veloppement institutionnel<\/span><\/b><span data-contrast=\"none\">\u202fau sein de notre secteur \u2014 construisant des parcours qui ne sont pas seulement \u00e9ducatifs, mais\u202f<\/span><b><span data-contrast=\"none\">fondamentaux pour un \u00e9cosyst\u00e8me mondial des m\u00e9taux pr\u00e9cieux plus responsable et professionnellement structur\u00e9<\/span><\/b><span data-contrast=\"none\">.<\/span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\">\u00a0<\/span><\/p><p><span data-contrast=\"none\">Des informations compl\u00e9mentaires sur les programmes et les calendriers acad\u00e9miques seront communiqu\u00e9es lors de la prochaine phase.<\/span><span data-ccp-props=\"{&quot;134233117&quot;:true,&quot;134233118&quot;:true,&quot;201341983&quot;:0,&quot;335559739&quot;:0,&quot;335559740&quot;:240}\">\u00a0<\/span><\/p>\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/div>\n\t\t\t\t\t<\/div>\n\t\t<\/section>\n\t\t\t\t<section class=\"has_eae_slider elementor-section elementor-top-section elementor-element elementor-element-ff22f70 elementor-section-boxed elementor-section-height-default elementor-section-height-default\" data-eae-slider=\"27736\" data-id=\"ff22f70\" data-element_type=\"section\">\n\t\t\t\t\t\t<div class=\"elementor-container elementor-column-gap-default\">\n\t\t\t\t\t<div class=\"has_eae_slider elementor-column elementor-col-100 elementor-top-column elementor-element elementor-element-dde6bc5\" data-eae-slider=\"46190\" data-id=\"dde6bc5\" data-element_type=\"column\">\n\t\t\t<div class=\"elementor-widget-wrap elementor-element-populated\">\n\t\t\t\t\t\t<div class=\"elementor-element elementor-element-c1c2a25 elementor-widget elementor-widget-heading\" data-id=\"c1c2a25\" data-element_type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">\u0634\u0631\u0643\u0629 \u0633\u0627\u0645 \u0644\u0644\u0645\u0639\u0627\u062f\u0646 \u0627\u0644\u062b\u0645\u064a\u0646\u0629 \u062a\u0639\u0632\u0632 \u0627\u0644\u062a\u0637\u0648\u0631 \u0627\u0644\u0623\u0643\u0627\u062f\u064a\u0645\u064a \u0627\u0644\u0639\u0627\u0644\u0645\u064a \u0645\u0646 \u062e\u0644\u0627\u0644 \u0634\u0631\u0627\u0643\u062a\u0647\u0627 \u0645\u0639 \u0645\u062f\u0631\u0633\u0629 \u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0641\u064a \u0644\u064a\u0648\u0646 <\/h2>\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t\t<\/